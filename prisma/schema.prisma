generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (e.g. Neon's `-pooler` host) — used by the running app.
  // Serverless functions open many concurrent connections; without pooling
  // they exhaust Postgres's connection limit and requests hang instead of failing.
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection — used only for `prisma migrate deploy`.
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUBSCRIBER
  HANDICAPPER
  ADMIN
}

enum PickResult {
  PENDING
  WIN
  LOSS
  PUSH
  VOID
}

enum PickSport {
  NFL
  NBA
  WNBA
  MLB
  NHL
  NCAAF
  NCAAB
  SOCCER
  GOLF
  TENNIS
  UFC_MMA
  OTHER
}

enum BetType {
  SPREAD
  MONEYLINE
  TOTAL
  PROP
  PARLAY
  FUTURES
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

// The handicapper's own plan with the platform (what THEY pay US, and at
// what commission rate) — distinct from Subscription, which is a fan
// paying a handicapper for picks.
enum HandicapperPlan {
  FREE
  SILVER
  GOLD
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  role           Role      @default(SUBSCRIBER)
  // Soft ban: suspended users can't sign in or act; data stays intact.
  suspendedAt    DateTime?
  // Superadmins have every admin permission and can manage other admins.
  // Bootstrapped from ADMIN_EMAILS/SUPERADMIN_EMAILS; can also be granted in-app.
  isSuperAdmin   Boolean   @default(false)
  // For scoped admins (role ADMIN, not superadmin): the set of admin-panel
  // permission keys they're allowed. See ADMIN_PERMISSIONS in src/lib/permissions.ts.
  adminPermissions String[] @default([])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]

  handicapper    HandicapperProfile?
  subscriptions  Subscription[]        @relation("SubscriberSubscriptions")
  follows        Follow[]              @relation("UserFollows")

  stripeCustomerId String? @unique

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model HandicapperProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  handle      String   @unique
  displayName String
  bio         String?  @db.Text
  avatarUrl   String?
  coverUrl    String?
  sports      PickSport[] @default([])
  isVerified  Boolean  @default(false)
  // Soft suspension: hidden from listings, profile 404s, can't post picks or
  // take new subscribers; existing data stays intact.
  suspendedAt DateTime?

  // Social links shown (with icons) on the public profile and cards. Null = not
  // provided. Stored as full normalized URLs.
  xUrl         String?
  instagramUrl String?
  youtubeUrl   String?
  tiktokUrl    String?
  discordUrl   String?
  telegramUrl  String?
  websiteUrl   String?

  // Subscriber pricing packages. Monthly is the required anchor; weekly and
  // annual are optional add-ons (null = the handicapper doesn't offer them).
  monthlyPriceCents Int   @default(2999)
  weeklyPriceCents  Int?
  annualPriceCents  Int?

  stripeAccountId      String?  @unique
  stripeAccountReady   Boolean  @default(false)
  stripeProductId      String?
  stripePriceId        String?  // monthly package
  stripeWeeklyPriceId  String?
  stripeAnnualPriceId  String?

  // The handicapper's plan with the platform — controls commission rate
  // (see commissionPercentForPlan in src/lib/plans.ts) and, for GOLD,
  // homepage/leaderboard featuring. Billing here runs on the platform's own
  // Stripe account (no Connect), separate from the stripeAccount* fields
  // above which are for receiving subscriber payments.
  plan                    HandicapperPlan    @default(FREE)
  planInterval            BillingInterval?
  planStatus              SubscriptionStatus @default(ACTIVE)
  planStripeCustomerId    String?            @unique
  planStripeSubscriptionId String?           @unique
  planCurrentPeriodEnd    DateTime?
  planCancelAtPeriodEnd   Boolean            @default(false)

  picks         Pick[]
  subscriptions Subscription[] @relation("HandicapperSubscriptions")
  followers     Follow[]       @relation("HandicapperFollowers")
  testimonials  Testimonial[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([handle])
}

model Pick {
  id             String     @id @default(cuid())
  handicapperId  String
  handicapper    HandicapperProfile @relation(fields: [handicapperId], references: [id], onDelete: Cascade)

  sport          PickSport
  league         String?
  matchup        String
  betType        BetType
  selection      String
  odds           Int
  units          Float      @default(1)
  analysis       String?    @db.Text
  result         PickResult @default(PENDING)
  isPremium      Boolean    @default(true)

  eventStartsAt  DateTime
  settledAt      DateTime?
  // Who graded this pick: the owner's userId (self), an admin's userId, or
  // "auto" for score-based settlement. Null while pending. The audit column
  // behind the "verified records" promise.
  settledBy      String?
  // Set for picks created from the odds schedule — lets auto-settlement match
  // this pick to a final score.
  oddsApiEventId String?
  oddsApiSportKey String?

  // For a PARLAY bet: the individual legs. `odds` on the parent Pick holds the
  // combined (multiplied) American odds; each leg keeps its own line.
  parlayLegs     ParlayLeg[]

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([handicapperId, createdAt])
  @@index([result])
}

// One selection within a parlay Pick. Legs are display-only detail; the parlay
// is graded as a whole on the parent Pick.
model ParlayLeg {
  id        String    @id @default(cuid())
  pickId    String
  pick      Pick      @relation(fields: [pickId], references: [id], onDelete: Cascade)

  sport     PickSport?
  league    String?
  matchup   String
  selection String
  odds      Int
  order     Int        @default(0)

  createdAt DateTime   @default(now())

  @@index([pickId])
}

// A short quote a handicapper adds from one of their subscribers, shown on the
// public profile. Curated by the handicapper (not open user reviews).
model Testimonial {
  id            String   @id @default(cuid())
  handicapperId String
  handicapper   HandicapperProfile @relation(fields: [handicapperId], references: [id], onDelete: Cascade)

  author        String
  quote         String   @db.Text
  createdAt     DateTime @default(now())

  @@index([handicapperId])
}

// One row per admin mutation — who did what to which record, when.
model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorEmail String
  action     String
  targetType String
  targetId   String
  detail     String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// Small key-value store for admin-configurable settings (announcement banner,
// cached odds-quota snapshot, ...).
model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model Subscription {
  id             String   @id @default(cuid())
  subscriberId   String
  subscriber     User     @relation("SubscriberSubscriptions", fields: [subscriberId], references: [id], onDelete: Cascade)

  handicapperId  String
  handicapper    HandicapperProfile @relation("HandicapperSubscriptions", fields: [handicapperId], references: [id], onDelete: Cascade)

  stripeSubscriptionId String? @unique
  stripeCustomerId     String?

  status         SubscriptionStatus @default(INCOMPLETE)
  currentPeriodEnd DateTime?
  cancelAtPeriodEnd Boolean @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([subscriberId, handicapperId])
  @@index([handicapperId, status])
}

// A free "follow": a customer tracking a handicapper's stats without paying
// for their picks. Distinct from Subscription, which is the paid relationship
// that unlocks premium picks.
model Follow {
  id            String   @id @default(cuid())
  followerId    String
  follower      User     @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)

  handicapperId String
  handicapper   HandicapperProfile @relation("HandicapperFollowers", fields: [handicapperId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())

  @@unique([followerId, handicapperId])
  @@index([handicapperId])
}
