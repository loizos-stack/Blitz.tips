generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (e.g. Neon's `-pooler` host) — used by the running app.
  // Serverless functions open many concurrent connections; without pooling
  // they exhaust Postgres's connection limit and requests hang instead of failing.
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection — used only for `prisma migrate deploy`.
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUBSCRIBER
  HANDICAPPER
  ADMIN
}

enum PickResult {
  PENDING
  WIN
  LOSS
  PUSH
  VOID
}

enum PickSport {
  NFL
  NBA
  WNBA
  MLB
  NHL
  NCAAF
  NCAAB
  SOCCER
  GOLF
  TENNIS
  UFC_MMA
  OTHER
}

enum BetType {
  SPREAD
  MONEYLINE
  TOTAL
  PROP
  PARLAY
  FUTURES
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

// Currencies a handicapper can price their packages in.
enum PriceCurrency {
  USD
  EUR
  GBP
}

// The handicapper's own plan with the platform (what THEY pay US, and at
// what commission rate) — distinct from Subscription, which is a fan
// paying a handicapper for picks.
enum HandicapperPlan {
  FREE
  SILVER
  GOLD
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  // Login identity chosen at signup; usable in place of email to sign in.
  // Stored lowercased so uniqueness and lookups are case-insensitive. Nullable
  // for legacy/Google accounts that predate the field (they sign in by email).
  username         String?   @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  // Self-reported country, collected at signup (ISO country name).
  country          String?
  role             Role      @default(SUBSCRIBER)
  // Soft ban: suspended users can't sign in or act; data stays intact.
  suspendedAt      DateTime?
  // Brute-force protection: consecutive failed password attempts and, once the
  // threshold is hit, the moment the account unlocks. Reset on a successful login.
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  // Superadmins have every admin permission and can manage other admins.
  // Bootstrapped from ADMIN_EMAILS/SUPERADMIN_EMAILS; can also be granted in-app.
  isSuperAdmin     Boolean   @default(false)
  // For scoped admins (role ADMIN, not superadmin): the set of admin-panel
  // permission keys they're allowed. See ADMIN_PERMISSIONS in src/lib/permissions.ts.
  adminPermissions String[]  @default([])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  handicapper       HandicapperProfile?
  subscriptions     Subscription[]      @relation("SubscriberSubscriptions")
  reviews           Review[]            @relation("UserReviews")
  adminTabViews     AdminTabView[]      @relation("AdminTabViews")
  follows           Follow[]            @relation("UserFollows")
  notifications     Notification[]
  pushSubscriptions PushSubscription[]

  // Live-chat support: chats this user (as an agent) is handling + their
  // online-presence heartbeat.
  agentChats    Chat[]         @relation("AgentChats")
  agentPresence AgentPresence?

  // Blog posts this user (an admin) authored.
  blogPosts BlogPost[] @relation("BlogAuthor")

  // Handicapping-contest entries (Supercapper Contest and any future contests).
  contestEntries ContestEntry[] @relation("UserContestEntries")

  // Per-channel notification opt-outs (in-app is always on). Default on.
  notifyEmail    Boolean @default(true)
  notifyPush     Boolean @default(true)
  notifyTelegram Boolean @default(true)
  notifyDiscord  Boolean @default(true)

  // Linked chat identities for DM notifications (null until the user connects).
  telegramChatId    String?
  telegramLinkToken String? @unique
  discordUserId     String?

  stripeCustomerId String? @unique

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Short numeric email-verification codes used by the signup onboarding flow
// (one active code per email; replaced on resend).
model EmailVerificationCode {
  id         String   @id @default(cuid())
  identifier String   @unique
  code       String
  expires    DateTime
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())
}

model HandicapperProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  handle      String      @unique
  displayName String
  bio         String?     @db.Text
  avatarUrl   String?
  coverUrl    String?
  sports      PickSport[] @default([])
  isVerified  Boolean     @default(false)
  // Soft suspension: hidden from listings, profile 404s, can't post picks or
  // take new subscribers; existing data stays intact.
  suspendedAt DateTime?

  // Social links shown (with icons) on the public profile and cards. Null = not
  // provided. Stored as full normalized URLs.
  xUrl         String?
  instagramUrl String?
  youtubeUrl   String?
  tiktokUrl    String?
  discordUrl   String?
  telegramUrl  String?
  websiteUrl   String?

  // Subscriber pricing packages. Monthly is the required anchor; weekly and
  // annual are optional add-ons (null = the handicapper doesn't offer them).
  monthlyPriceCents Int  @default(2999)
  weeklyPriceCents  Int?
  annualPriceCents  Int?

  // Optional free-trial length (1 or 2 days) applied to weekly/monthly Stripe
  // subscriptions only — never annual. null/0 = no trial.
  subscriptionTrialDays Int?

  // Currency the handicapper's package prices are denominated and charged in
  // (Stripe + crypto). Prices above are integer minor units of this currency.
  priceCurrency PriceCurrency @default(USD)

  // Crypto payout wallets — where the platform sends the handicapper's cut of
  // crypto (NOWPayments) subscriptions. Internal only; never shown publicly.
  payoutEthAddress String?
  payoutBtcAddress String?

  stripeAccountId     String? @unique
  stripeAccountReady  Boolean @default(false)
  stripeProductId     String?
  stripePriceId       String? // monthly package
  stripeWeeklyPriceId String?
  stripeAnnualPriceId String?

  // The handicapper's plan with the platform — controls commission rate
  // (see commissionPercentForPlan in src/lib/plans.ts) and, for GOLD,
  // homepage/leaderboard featuring. Billing here runs on the platform's own
  // Stripe account (no Connect), separate from the stripeAccount* fields
  // above which are for receiving subscriber payments.
  plan                     HandicapperPlan    @default(FREE)
  planInterval             BillingInterval?
  planStatus               SubscriptionStatus @default(ACTIVE)
  planStripeCustomerId     String?            @unique
  planStripeSubscriptionId String?            @unique
  planCurrentPeriodEnd     DateTime?
  planCancelAtPeriodEnd    Boolean            @default(false)
  // Whether this handicapper has already consumed their one-time 1-month free
  // trial on a paid (Silver/Gold) plan — set the first time a trial starts, so
  // canceling and re-subscribing doesn't grant another free month.
  planTrialUsed            Boolean            @default(false)

  picks         Pick[]
  subscriptions Subscription[] @relation("HandicapperSubscriptions")
  followers     Follow[]       @relation("HandicapperFollowers")
  reviews       Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([handle])
}

model Pick {
  id            String             @id @default(cuid())
  handicapperId String
  handicapper   HandicapperProfile @relation(fields: [handicapperId], references: [id], onDelete: Cascade)

  sport     PickSport
  league    String?
  matchup   String
  betType   BetType
  selection String
  odds      Int
  units     Float      @default(1)
  analysis  String?    @db.Text
  result    PickResult @default(PENDING)
  isPremium Boolean    @default(true)

  eventStartsAt   DateTime
  settledAt       DateTime?
  // Who graded this pick: the owner's userId (self), an admin's userId, or
  // "auto" for score-based settlement. Null while pending. The audit column
  // behind the "verified records" promise.
  settledBy       String?
  // Set for picks created from the odds schedule — lets auto-settlement match
  // this pick to a final score.
  oddsApiEventId  String?
  oddsApiSportKey String?

  // For a PARLAY bet: the individual legs. `odds` on the parent Pick holds the
  // combined (multiplied) American odds; each leg keeps its own line.
  parlayLegs ParlayLeg[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([handicapperId, createdAt])
  @@index([result])
}

// One selection within a parlay Pick. Legs are display-only detail; the parlay
// is graded as a whole on the parent Pick.
model ParlayLeg {
  id     String @id @default(cuid())
  pickId String
  pick   Pick   @relation(fields: [pickId], references: [id], onDelete: Cascade)

  sport     PickSport?
  league    String?
  matchup   String
  selection String
  odds      Int
  order     Int        @default(0)

  createdAt DateTime @default(now())

  @@index([pickId])
}

// A subscriber's review of a handicapper: a 1–5 star rating with an optional
// written note, shown on the public profile. Only users who are (or were) paid
// subscribers of the handicapper can leave one — enforced in the API, not the
// schema. One review per subscriber per handicapper (they can edit it).
//
// Reviews are held for admin moderation: a new or edited review lands as PENDING
// and only appears publicly once an admin marks it APPROVED (so foul/hate
// language can be caught first). REJECTED reviews stay hidden.
model Review {
  id            String             @id @default(cuid())
  handicapperId String
  handicapper   HandicapperProfile @relation(fields: [handicapperId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("UserReviews", fields: [authorId], references: [id], onDelete: Cascade)

  rating Int // 1–5 stars
  body   String? @db.Text

  status      ReviewStatus @default(PENDING)
  moderatedAt DateTime?
  moderatedBy String? // admin userId who approved/rejected it

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([handicapperId, authorId])
  @@index([handicapperId, status])
  @@index([status, createdAt])
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// Per-admin "last viewed" marker for an admin tab. Powers the number bubbles in
// the admin nav for tabs whose badge means "new since you last looked"
// (users, handicappers, subscriptions). Queue tabs (tickets/chats/reviews) badge
// off live state instead and don't need a marker.
model AdminTabView {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation("AdminTabViews", fields: [userId], references: [id], onDelete: Cascade)
  tab    String
  seenAt DateTime @default(now())

  @@unique([userId, tab])
}

// One row per admin mutation — who did what to which record, when.
model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorEmail String
  action     String
  targetType String
  targetId   String
  detail     String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// Small key-value store for admin-configurable settings (announcement banner,
// cached odds-quota snapshot, ...).
model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model Subscription {
  id           String @id @default(cuid())
  subscriberId String
  subscriber   User   @relation("SubscriberSubscriptions", fields: [subscriberId], references: [id], onDelete: Cascade)

  handicapperId String
  handicapper   HandicapperProfile @relation("HandicapperSubscriptions", fields: [handicapperId], references: [id], onDelete: Cascade)

  stripeSubscriptionId String? @unique
  stripeCustomerId     String?

  status            SubscriptionStatus @default(INCOMPLETE)
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean            @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([subscriberId, handicapperId])
  @@index([handicapperId, status])
}

// A crypto payment for a fixed-length access pass (NOWPayments invoice).
// Crypto can't auto-renew or split funds like Stripe Connect: payments land in
// the platform's NOWPayments account, and confirmed rows double as the earnings
// ledger showing what each handicapper is owed (netCents).
model CryptoPayment {
  id            String @id @default(cuid())
  chargeCode    String @unique // our order id, echoed back by the NOWPayments IPN
  subscriberId  String
  handicapperId String

  interval        BillingIntervalPass
  amountCents     Int // what the subscriber paid (USD-priced)
  commissionCents Int // platform's cut at time of purchase
  netCents        Int // owed to the handicapper

  status      CryptoPaymentStatus @default(PENDING)
  confirmedAt DateTime?
  createdAt   DateTime            @default(now())

  @@index([handicapperId, status])
  @@index([subscriberId])
}

enum CryptoPaymentStatus {
  PENDING
  CONFIRMED
  EXPIRED
}

enum BillingIntervalPass {
  WEEKLY
  MONTHLY
  ANNUAL
}

// A free "follow": a customer tracking a handicapper's stats without paying
// for their picks. Distinct from Subscription, which is the paid relationship
// that unlocks premium picks.
model Follow {
  id         String @id @default(cuid())
  followerId String
  follower   User   @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)

  handicapperId String
  handicapper   HandicapperProfile @relation("HandicapperFollowers", fields: [handicapperId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([followerId, handicapperId])
  @@index([handicapperId])
}

// An in-app notification for the bell/notification center. Also the source of
// truth that a given event happened; email and web push are additional
// delivery channels driven off the same fan-out.
model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type  String // e.g. "pick.new"
  title String
  body  String  @db.Text
  url   String?

  // Loose references (no FK cascade needed — notifications are disposable).
  handicapperId String?
  pickId        String?

  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
}

// A browser Web Push subscription (endpoint + keys) for a user. A user may have
// several (one per device/browser). Removed when the push service reports it's
// gone (404/410).
model PushSubscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// Support ticket opened from the contact / FAQ form. Tracks the whole thread of
// messages between the visitor and admins so the discussion has a record.
enum TicketStatus {
  OPEN
  CLOSED
}

enum TicketAuthor {
  CUSTOMER
  ADMIN
}

model Ticket {
  id        String          @id @default(cuid())
  name      String
  email     String
  subject   String?
  // Enquiry category chosen in the contact form (see src/lib/ticket-categories).
  // Nullable for tickets created before the field existed.
  category  String?
  status    TicketStatus    @default(OPEN)
  messages  TicketMessage[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([status, updatedAt])
}

model TicketMessage {
  id        String       @id @default(cuid())
  ticketId  String
  ticket    Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    TicketAuthor
  body      String       @db.Text
  createdAt DateTime     @default(now())

  @@index([ticketId, createdAt])
}

// ---------------------------------------------------------------------------
// Live chat + AI chatbot
//
// Anonymous visitors open a Chat from the on-site widget. It starts in BOT mode
// (answered by the FAQ chatbot). If the visitor asks for a human it moves to
// WAITING; an admin/support agent claiming it moves it to LIVE. When no agent is
// online the widget falls back to the contact form (which opens a Ticket).
// ---------------------------------------------------------------------------

enum ChatStatus {
  BOT // conversing with the automated assistant
  WAITING // visitor asked for a human, awaiting an agent
  LIVE // an agent has claimed and is handling it
  CLOSED
}

enum ChatAuthor {
  VISITOR
  BOT
  AGENT
  SYSTEM
}

model Chat {
  id           String        @id @default(cuid())
  // Random secret returned once at creation; the anonymous visitor's browser
  // must present it to read or post to this chat (keeps threads private).
  token        String        @default(cuid())
  visitorName  String?
  visitorEmail String?
  status       ChatStatus    @default(BOT)
  // The agent currently handling a LIVE chat (null while in BOT/WAITING).
  agentId      String?
  agent        User?         @relation("AgentChats", fields: [agentId], references: [id], onDelete: SetNull)
  messages     ChatMessage[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status, updatedAt])
}

model ChatMessage {
  id        String     @id @default(cuid())
  chatId    String
  chat      Chat       @relation(fields: [chatId], references: [id], onDelete: Cascade)
  author    ChatAuthor
  body      String     @db.Text
  createdAt DateTime   @default(now())

  @@index([chatId, createdAt])
}

// Heartbeat table: an admin/support agent is "online" while lastSeen is recent
// (the admin Chat tab pings it periodically). Drives whether the visitor widget
// offers live chat or falls back to the contact form.
model AgentPresence {
  userId   String   @id
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastSeen DateTime @default(now())

  @@index([lastSeen])
}

// A blog / content post for SEO and top-of-funnel traffic. Authored in the admin
// Blog tab (rich-text HTML body), published to /blog and /blog/[slug]. Only
// PUBLISHED posts (with a publishedAt in the past) are shown publicly.
enum BlogStatus {
  DRAFT
  PUBLISHED
}

model BlogPost {
  id            String  @id @default(cuid())
  // URL slug, unique and lowercased (e.g. "how-we-verify-records").
  slug          String  @unique
  title         String
  // Short summary for listing cards, meta description, and social preview.
  excerpt       String  @db.Text
  // Rich-text HTML body, authored in the admin editor.
  contentHtml   String  @db.Text
  // Optional hero/social image URL (Vercel Blob or any allowed remote host).
  coverImageUrl String?

  status      BlogStatus @default(DRAFT)
  // When it went (or is scheduled to go) live. Set on first publish.
  publishedAt DateTime?

  authorId String
  author   User   @relation("BlogAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt])
}

// A one-time crypto payment (NOWPayments) for a handicapper's own Silver/Gold
// plan — the crypto alternative to the recurring Stripe plan subscription.
// Prepaid and fixed-term: it activates the plan for one interval and never
// auto-renews (paying again extends from the current end date).
model PlanCryptoPayment {
  id            String @id @default(cuid())
  chargeCode    String @unique // our order id (blitzplan_…), echoed by the IPN
  handicapperId String

  plan        HandicapperPlan
  interval    BillingInterval
  amountCents Int

  status      CryptoPaymentStatus @default(PENDING)
  confirmedAt DateTime?
  createdAt   DateTime            @default(now())

  @@index([handicapperId, status])
}

// Generic fixed-window rate limiter shared across serverless instances (there's
// no Redis). One row per bucket key (e.g. "register:1.2.3.4"); `count` resets
// whenever `windowStart` ages past the caller's window.
model RateLimit {
  key         String   @id
  count       Int      @default(0)
  windowStart DateTime @default(now())
}

// ─── Handicapping contests (e.g. the Supercapper Contest) ───────────────────
// A free, ROI-ranked contest any user can enter by submitting picks during the
// window. Ranked by ROI over settled picks, with a minimum-pick floor so a
// couple of lucky bets can't win. Prizes are split across the top N places.
enum ContestStatus {
  DRAFT
  OPEN
  CLOSED
  SETTLED
}

model Contest {
  id              String        @id @default(cuid())
  slug            String        @unique
  name            String
  tagline         String?
  // Guaranteed pool (equals the sum of prizeSplitCents), stored in cents.
  prizePoolCents  Int
  currency        String        @default("USD")
  // Cents awarded to each place; index 0 = 1st. Length = number of winners.
  prizeSplitCents Int[]         @default([])
  // Minimum settled picks an entry needs before it's ranked.
  minPicks        Int           @default(20)
  startsAt        DateTime
  endsAt          DateTime
  status          ContestStatus @default(DRAFT)
  settledAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  entries ContestEntry[]
  ipLogs  ContestIpLog[]

  @@index([status])
}

model ContestEntry {
  id                 String    @id @default(cuid())
  contestId          String
  contest            Contest   @relation(fields: [contestId], references: [id], onDelete: Cascade)
  userId             String
  user               User      @relation("UserContestEntries", fields: [userId], references: [id], onDelete: Cascade)
  // Final standings, written when the contest is settled.
  finalRank          Int?
  prizeCents         Int?
  paidAt             DateTime?
  // Anti-fraud: a disqualified entry is excluded from the standings and payouts.
  disqualifiedAt     DateTime?
  disqualifiedReason String?
  createdAt          DateTime  @default(now())

  picks  ContestPick[]
  ipLogs ContestIpLog[]

  @@unique([contestId, userId])
  @@index([contestId])
}

// Fraud signal log: the IP + device an entrant used when joining a contest and
// each time they submitted a pick. Shared IPs / devices across entries are the
// primary multi-account / collusion signal surfaced to admins.
model ContestIpLog {
  id        String       @id @default(cuid())
  contestId String
  contest   Contest      @relation(fields: [contestId], references: [id], onDelete: Cascade)
  entryId   String
  entry     ContestEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  userId    String
  ip        String
  userAgent String?
  action    String // "join" | "pick"
  createdAt DateTime     @default(now())

  @@index([contestId, ip])
  @@index([entryId])
}

model ContestPick {
  id              String       @id @default(cuid())
  entryId         String
  entry           ContestEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  sport           PickSport
  league          String?
  matchup         String
  selection       String
  odds            Int
  units           Float        @default(1)
  result          PickResult   @default(PENDING)
  eventStartsAt   DateTime
  settledAt       DateTime?
  settledBy       String?
  // Forward-compat with auto-settlement from the odds feed (unused in v1).
  oddsApiEventId  String?
  oddsApiSportKey String?
  createdAt       DateTime     @default(now())

  @@index([entryId])
  @@index([result])
}
