# Postgres connection strings.
# Locally these can be identical. On a pooled host (Neon, Supabase, etc.) DATABASE_URL
# MUST be the pooled connection (used by the running app under serverless concurrency)
# and DIRECT_URL MUST be the direct/non-pooled connection (used only by `prisma migrate
# deploy`) — pointing the app itself at a direct connection will exhaust Postgres's
# connection limit under load and requests will hang instead of failing.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/blitztips"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/blitztips"

# NextAuth / Auth.js
# Generate with: npx auth secret   (or `openssl rand -base64 32`)
AUTH_SECRET="replace-with-a-random-32-byte-secret"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Stripe (https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# The Odds API (https://the-odds-api.com) — powers the "pick from schedule" feed
# of upcoming games with live odds in the handicapper dashboard. Optional: without
# it, handicappers can still enter picks manually. Free tier is 500 credits/month;
# responses are cached for an hour to stay within it.
THE_ODDS_API_KEY=""

# Where the public Contact form (/contact and the FAQ form) delivers messages.
# Defaults to support@blitz.tips. Uses Resend (RESEND_API_KEY) to send.
CONTACT_EMAIL=""

# Vercel Blob — stores handicapper profile/cover image uploads. On Vercel,
# create a Blob store (Storage tab) and this token is injected automatically.
# For local dev without a store, set BLOB_LOCAL_DIR=public/uploads instead to
# write uploads to disk (do NOT use the local shim in production — Vercel's
# runtime filesystem is ephemeral).
BLOB_READ_WRITE_TOKEN=""
# BLOB_LOCAL_DIR="public/uploads"

# Comma-separated emails that get the ADMIN role (and the /admin panel) on
# sign-in. These are SUPERADMINS: full access plus the Permissions tab, where
# they create scoped admins and grant them specific tabs. This is how the first
# owner is bootstrapped — no DB edit needed.
ADMIN_EMAILS="loizos@protopapas.net"

# Optional: additional superadmin emails, kept separate from ADMIN_EMAILS if you
# prefer. Same effect — full access and can manage other admins' permissions.
SUPERADMIN_EMAILS=""

# Any random string. Vercel sends it as a Bearer token when invoking the
# daily auto-settle cron (/api/cron/auto-settle); generate with
# `openssl rand -hex 24`. Admins can also trigger the run from /admin/system.
CRON_SECRET=""

# Bet-slip OCR for parlays works out of the box using free, on-server Tesseract
# OCR (no key needed). Set ANTHROPIC_API_KEY to upgrade to Claude vision for
# much better accuracy and structured leg extraction. OCR_MODEL optionally
# overrides the vision model (defaults to a Claude Haiku).
ANTHROPIC_API_KEY=""
OCR_MODEL=""

# Resend (https://resend.com) — sends the email-verification message after
# signup. Without RESEND_API_KEY the app skips sending and logs the link
# instead (fine for local dev). EMAIL_FROM must be an address on a domain
# you've verified in Resend.
RESEND_API_KEY=""
EMAIL_FROM="Blitz.tips <noreply@yourdomain.com>"

# Base URL for absolute links (verification emails, Stripe redirects). Set for
# local dev. In production on Vercel it's auto-detected from the project's
# production domain, so a custom value is only needed for a non-Vercel host or
# to override; a stale *.vercel.app value here is ignored (see src/lib/site.ts).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Web Push notifications (Phase 2). Generate a VAPID key pair once with:
#   npx web-push generate-vapid-keys
# Set both keys in every environment that should send browser push. Without
# them, in-app + email notifications still work and the "Push on this device"
# toggle is simply hidden. VAPID_SUBJECT is a contact mailto: or https: URL.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:support@blitz.tips"

# Telegram DM notifications (Phase 3). Create a bot with @BotFather, then set
# its token + username here and point its webhook at
# https://<your-domain>/api/telegram/webhook (secret_token = the value below):
#   curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://blitz.tips/api/telegram/webhook&secret_token=<SECRET>"
# Unset = the Telegram option is hidden.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_WEBHOOK_SECRET=""

# Discord DM notifications (Phase 3). Create an app + bot at
# https://discord.com/developers, add https://<your-domain>/api/discord/callback
# as an OAuth redirect, and invite the bot to your community server (it can only
# DM users who share a server with it). Unset = the Discord option is hidden.
DISCORD_BOT_TOKEN=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
